# 1. Use the SDK image to build
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /app

# 2. Copy the csproj from the subfolder to the container
COPY ["FlashcardAPI/FlashcardAPI.csproj", "FlashcardAPI/"]

# 3. Restore dependencies
RUN dotnet restore "FlashcardAPI/FlashcardAPI.csproj"

# 4. Copy everything else and build
COPY . .
WORKDIR "/app/FlashcardAPI"
RUN dotnet build "FlashcardAPI.csproj" -c Release -o /app/build

# 5. Publish
FROM build AS publish
RUN dotnet publish "FlashcardAPI.csproj" -c Release -o /app/publish

# 6. Final stage: run the app
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS final
WORKDIR /app
COPY --from=publish /app/publish .
ENTRYPOINT ["dotnet", "FlashcardAPI.dll"]